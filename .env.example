# Foursquare Places API v3 — opzionale, aggiunge POI da Foursquare alla scansione
FSQ_API_KEY=

# Google Places API (New) — opzionale, aggiunge POI da Google Places alla scansione
# ATTENZIONE: oltre il credito gratuito mensile ($200/mese) si pagano soldi reali.
# Config di default (11 call/scan, ~$0.40/scan Pro SKU) sta ampiamente dentro il free tier.
# Non aumentare i limiti sotto senza prima stimare i costi.
GOOGLE_PLACES_API_KEY=

# Kill-switch veloce: "0" disattiva Google Places anche se la chiave è presente
GOOGLE_PLACES_ENABLED=1

# Hard cap al numero di chiamate Google Places per scansione (safety)
GOOGLE_PLACES_MAX_CALLS=15

# Hard cap al numero totale di risultati Google Places per scansione (safety)
GOOGLE_PLACES_MAX_RESULTS=180

# Scoring composito — categorie target (peso 0.2 se non impostato)
# Esempio: SCORING_CATEGORIES=Ristorazione,Artigiani
SCORING_CATEGORIES=

# Distanza massima in km usata nello scoring (default: 50)
SCORING_MAX_DISTANCE_KM=50
